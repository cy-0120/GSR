# 서버 포트
PORT=3000

# Anthropic Claude API 키 (선택 사항)
# 설정하지 않으면 규칙 기반 폴백 분석기가 대신 동작합니다.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- 배포(Vercel) 전용 설정 ---
# 로컬 개발 시에는 비워두세요. data/ 폴더에 파일 DB가 자동 생성됩니다.
# Vercel 등 서버리스 환경은 파일시스템이 읽기 전용이므로 Turso(libSQL) 원격 DB가 필요합니다.
# https://turso.tech 에서 무료 데이터베이스를 만들고 아래 두 값을 채우세요.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Vercel 프로젝트의 Storage 탭에서 Blob 스토어를 생성하면 Vercel이 자동으로 채워줍니다.
# 로컬 개발에서는 비워두면 public/uploads/ 폴더에 사진이 저장됩니다.
BLOB_READ_WRITE_TOKEN=
